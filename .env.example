# SMTP Settings for Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=ntkdung1206@gmail.com

# Gemini API Credentials
GEMINI_API_KEY=

# Security Encryption Key
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Supabase (Postgres) — dùng làm database dùng chung, thay cho việc lưu
# src/db_store.json trực tiếp trong repo. Lấy 2 giá trị này tại:
# Supabase Dashboard > Project Settings > API.
#
# QUAN TRỌNG: đây là biến phía SERVER (không có tiền tố VITE_), nên KHÔNG
# bao giờ bị nhúng vào file JS công khai của trình duyệt. Dùng
# SERVICE_ROLE key (không phải anon key) vì server cần toàn quyền đọc/ghi
# và tự quản lý việc phân quyền Admin/Editor/Viewer ở tầng ứng dụng.
# Tuyệt đối không thêm tiền tố VITE_ vào 2 biến này.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
